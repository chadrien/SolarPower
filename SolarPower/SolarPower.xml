  <Frame name="SolarPowerFrame" movable="true" frameStrata="LOW" enableMouse="true" parent="UIParent" hidden="false">
	  <Size>
		  <AbsDimension x="1" y="1" />
	  </Size>
	  <Anchors>
		  <Anchor point="CENTER">
			  <Offset x="0" y="0"/>
		  </Anchor>
	  </Anchors>
	  <Frames>
		  <CheckButton name="SolarPowerAnchor" enableMouse="true" frameStrata="LOW" inherits="SecureHandlerStateTemplate">
			  <Scripts>
				  <OnLoad>
					  self:RegisterForDrag("LeftButton");
					  self:RegisterForClicks("LeftButtonUp", "RightButtonUp");
				  </OnLoad>
				  <OnClick>
					  SolarPower:ClickHandle(self, arg1);
				  </OnClick>
				  <OnDragStart>
					  SolarPower:DragStart();
				  </OnDragStart>
				  <OnDragStop>
					  SolarPower:DragStop();
				  </OnDragStop>
				  <OnEnter>
					  GameTooltip:SetOwner(self, "ANCHOR_RIGHT");
					  GameTooltip:SetText(SolarPower.CONFIG_DRAGHANDLE);
					  GameTooltip:Show();
					  CursorUpdate();
				  </OnEnter>
				  <OnLeave>
					  GameTooltip:Hide();
				  </OnLeave>
			  </Scripts>
			  <Size>
				  <AbsDimension x="16" y="16" />
			  </Size>
			  <Anchors>
				  <Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER"/>
			  </Anchors>
			  <NormalTexture file="Interface\AddOns\SolarPower\Icons\draghandle" />
			  <CheckedTexture file="Interface\AddOns\SolarPower\Icons\draghandle-checked" />
		  </CheckButton>
		  <Frame name="SolarPowerHeader" toplevel="true" movable="true" enableMouse="true" resizable="true" frameStrata="LOW" inherits="SecureHandlerStateTemplate">
			  <Size x="1" y="1"/>
			  <Anchors>
				  <Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER"/>
			  </Anchors>
		  </Frame>
	  </Frames>
  </Frame>

