					  <Anchor point="TOPRIGHT" relativeTo="$parentTime2" relativePoint="TOPLEFT">
						  <Offset>
							  <AbsDimension x="7" y="0" /> 
						  </Offset>
					  </Anchor>
				  </Anchors>
			  </FontString>
		  </Layer>
	  </Layers>
	  <Scripts>
		  <PreClick>
			  SolarPower:ButtonPreClick(self, button);
		  </PreClick>
		  <OnMouseWheel>
			  if InCombatLockdown() then return false end
			  if (arg1==-1) then  --mouse wheel down
				  SolarPower:PerformCycle(SolarPower.player, self:GetAttribute("classID"), true);
			  else
				  SolarPower:PerformCycleBackwards(SolarPower.player, self:GetAttribute("classID"), true);
			  end
			  SolarPower:ButtonsUpdate();
		  </OnMouseWheel> 
	  </Scripts>
  </Button>

